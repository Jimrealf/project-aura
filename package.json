{
    "name": "project-aura",
    "version": "1.0.0",
    "description": "Scalable E-Commerce Platform using Microservices Architecture",
    "private": true,
    "workspaces": [
        "api-gateway",
        "services/*"
    ],
    "scripts": {
        "dev:gateway": "npm run dev --workspace=api-gateway",
        "dev:identity": "npm run dev --workspace=services/identity-service",
        "dev:catalog": "npm run dev --workspace=services/catalog-service",
        "dev:cart": "npm run dev --workspace=services/cart-service",
        "dev:order": "npm run dev --workspace=services/order-service",
        "test": "jest --passWithNoTests"
    },
    "keywords": [
        "ecommerce",
        "microservices",
        "typescript"
    ],
    "author": "",
    "license": "ISC",
    "devDependencies": {
        "@types/jest": "^30.0.0",
        "@types/supertest": "^7.2.0",
        "jest": "^30.2.0",
        "supertest": "^7.2.2",
        "ts-jest": "^29.4.6",
        "typescript": "^5.9.3"
    }
}
